# App server
PORT=5000

# Reader mode: auto | true | false
RADAR_SIMULATION=auto
RADAR_DISABLE_READER_THREAD=false
RADAR_SERVERLESS_AUTOSIM=false
RADAR_SERVERLESS_FRESH_SECONDS=2.5

# Radar buffer and visualization scale
RADAR_BUFFER_SIZE=500
RADAR_MAX_DISTANCE=250
RADAR_READ_INTERVAL=0.03

# Serial device settings
# Windows example: COM4
# Linux example: /dev/ttyUSB0
SERIAL_PORT=COM4
SERIAL_BAUD=9600
SERIAL_TIMEOUT=1

# Ingest API security (optional but recommended)
RADAR_INGEST_TOKEN=
RADAR_INGEST_MAX_BATCH=200

# Bridge utility defaults
RADAR_INGEST_URL=http://127.0.0.1:5000/ingest
RADAR_BRIDGE_BATCH_SIZE=10
RADAR_BRIDGE_FLUSH_INTERVAL=0.4
RADAR_BRIDGE_HTTP_TIMEOUT=8
RADAR_BRIDGE_SHOWCASE=false
RADAR_BRIDGE_SERVO_MODE=auto
RADAR_BRIDGE_INVERT_ANGLE=false
RADAR_BRIDGE_ANGLE_OFFSET=0
RADAR_BRIDGE_ANGLE_BIN_DEG=2
RADAR_BRIDGE_DISTANCE_MIN=3
RADAR_BRIDGE_DISTANCE_MAX=250
RADAR_BRIDGE_DISTANCE_SCALE=1.0
RADAR_BRIDGE_DISTANCE_OFFSET=0
RADAR_BRIDGE_MEDIAN_WINDOW=5
RADAR_BRIDGE_SMOOTH_ALPHA=0.35
RADAR_BRIDGE_FAST_ALPHA=0.78
RADAR_BRIDGE_FAST_NEAR_DISTANCE=90
RADAR_BRIDGE_MAX_STEP_CHANGE=18
RADAR_BRIDGE_JUMP_REJECT_CM=55
RADAR_BRIDGE_BIN_TIMEOUT_SEC=2.0
